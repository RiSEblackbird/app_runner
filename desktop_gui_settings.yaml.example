# Sample settings for desktop tools
# `app_runner` relative paths are resolved from the `app_runner` folder.
# `app_image_prompt_creator` relative paths are resolved from the `app_image_prompt_creator` folder.

app_runner:
  # Folder scanned by the "自動追記" feature and shown as the initial folder path.
  DEFAULT_FOLDER_PATH: .

  # VSCode command or absolute path to the executable.
  # On macOS/Linux, `code` works when the command is available in PATH.
  CODE_EXE_PATH: code

app_image_prompt_creator:
  # Window position record file.
  POSITION_FILE: window_position_app_image_prompt_creator.txt

  # Base folder for this app.
  BASE_FOLDER: .

  # Paths to data assets used by the app.
  DEFAULT_TXT_PATH: image_prompt_parts.txt
  DEFAULT_DB_PATH: image_prompt_parts.db
  EXCLUSION_CSV: exclusion_targets.csv
  ARRANGE_PRESETS_YAML: arrange_presets.yaml
  TAIL_PRESETS_YAML: tail_presets.yaml
  SORA_CHARACTERS_YAML: sora_characters.yaml

  # Avoid reusing the same prompt row when true.
  DEDUPLICATE_PROMPTS: true

  # LLM settings
  LLM_ENABLED: false
  LLM_MODEL: gpt-5.4-mini
  LLM_MAX_COMPLETION_TOKENS: 4500
  LLM_TIMEOUT: 30
  OPENAI_API_KEY_ENV: OPENAI_API_KEY
  # Some models only support the default temperature and should keep this false.
  LLM_INCLUDE_TEMPERATURE: false
  LLM_TEMPERATURE: 0.7
